{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "scripts": {
    "dev": "vite",
    "dev:live": "VITE_USE_LIVE_RPC=true vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "questions:info": "bun run scripts/print-local-question-set.ts",
    "questions:seed:release": "bun run scripts/seed-question-set.ts release",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@cartridge/connector": "^0.11.3-alpha.1",
    "@cartridge/controller": "^0.11.3-alpha.1",
    "@cartridge/presets": "^0.5.2",
    "@dojoengine/core": "^1.8.8",
    "@dojoengine/sdk": "^1.9.0",
    "@dojoengine/torii-client": "^1.8.2",
    "@noble/hashes": "^1.8.0",
    "@starknet-react/chains": "^5.0.3",
    "@starknet-react/core": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "starknet": "^8.9.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  }
}
